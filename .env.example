# Pflicht: Passwort für die Admin-Übersicht (HTTP Basic Auth).
# Tipp:  echo "ADMIN_PASSWORD=$(openssl rand -base64 24)" >> .env
ADMIN_PASSWORD=

# Optional: Benutzername für Basic Auth (Default: admin)
ADMIN_USER=admin

# Optional: Wenn der Server hinter einem Reverse-Proxy / Tunnel läuft, hier die
# öffentlich erreichbare Basis-URL setzen (z.B. https://gutachten.example.com).
# Wird nur für die Anzeige der Klient-Links in der Übersicht benutzt.
PUBLIC_BASE_URL=

# Server-Bind
PORT=8000
HOST=0.0.0.0

# Datenbank- und Template-Pfade
DB_PATH=./data/form_storage.db
DOCX_TEMPLATE_PATH=./templates/gutachten_template.docx

# Limits / CORS
MAX_FILE_SIZE=10485760
CORS_ORIGIN=*
SACHVERSTAENDIGER_ORT=München
